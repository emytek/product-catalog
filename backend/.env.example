# =============================================================================
# Product Catalog API — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file to source control.
#
# DATABASE: SAP HANA Cloud (active)
# To switch back to Azure SQL Server, see the SQL Server section below.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Allowed origins for CORS (comma-separated, no spaces)
# In development this is the ui5 serve port; in BTP it is the approuter URL.
CORS_ORIGIN=http://localhost:8080,http://localhost:5000

# =============================================================================
# SAP HANA Cloud Connection (ACTIVE — use these for local dev and BTP)
# =============================================================================
# Where to find these values:
#   BTP Cockpit → SAP HANA Cloud Central → Your instance → Actions → Copy SQL Endpoint
#   Format of DB_HOST: <guid>.hanacloud.ondemand.com
#   DB_PORT is almost always 443 (HANA Cloud uses SSL/HTTPS)
#   DB_SCHEMA: the schema created for you when the service was provisioned
#              (shown in HANA Database Explorer, usually matches your user name)

# Get these values from: cf service-key product-catalog-hana devkey
# The user and schema are AUTO-GENERATED (not DBADMIN) for the schema plan.
# They will look like: USER_ABC12345_XYZ
DB_HOST=<host from service key>
DB_PORT=443
DB_USER=<user from service key — e.g. USER_ABC12345_XYZ>
DB_PASSWORD=<password from service key>
DB_SCHEMA=<schema from service key — same value as DB_USER>

# SAP HANA Cloud uses managed certificates — set to false for BTP-hosted instances.
# Set to true only if you are using a custom/enterprise CA certificate.
DB_SSL_VALIDATE_CERT=false

# ── Connection Pool ───────────────────────────────────────────────────────────
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_ACQUIRE_TIMEOUT_MS=15000

# =============================================================================
# SQL SERVER REFERENCE  (Azure SQL Server — comment out HANA section and
#                        uncomment this block to roll back)
# =============================================================================
# DB_HOST=your-server.database.windows.net
# DB_PORT=1433
# DB_NAME=ProductCatalogDB
# DB_USER=sa
# DB_PASSWORD=YourStrong@Passw0rd
# DB_ENCRYPT=true
# DB_TRUST_CERT=false
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_ACQUIRE_TIMEOUT_MS=15000

# =============================================================================
# Redis (optional — enables distributed caching and Bull queues)
# =============================================================================
# Leave blank to fall back to in-process node-cache and synchronous queuing.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
CACHE_TTL_CATALOG_SECONDS=600

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── SAP BTP / Cloud Foundry  (populated automatically by CF runtime) ──────────
# These are set by CF when the app is pushed — do NOT set them manually here.
# PORT is overridden by CF; the app reads process.env.PORT at runtime.
# VCAP_SERVICES contains all bound service credentials as JSON.
