# # =============================================================================
# # Product Catalog API — Environment Variables Template
# # Copy this file to .env and fill in the values for your environment.
# # NEVER commit the .env file to source control.
# # =============================================================================

# # ── Server ────────────────────────────────────────────────────────────────────
# NODE_ENV=development
# PORT=3000
# API_VERSION=v1

# # Allowed origins for CORS (comma-separated list, no spaces)
# # In development this is the ui5 serve port; in BTP it is the approuter URL.
# CORS_ORIGIN=http://localhost:8080,http://localhost:5000

# # ── Microsoft SQL Server ──────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=ProductCatalogDB
# DB_USER=sa
# DB_PASSWORD=YourStrong@Passw0rd

# # Set to true for Azure SQL or any server using TLS (recommended in production)
# DB_ENCRYPT=false
# # Set to true only in dev/self-signed cert environments; false for production
# DB_TRUST_CERT=true

# # Connection Pool tuning
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_ACQUIRE_TIMEOUT_MS=15000

# # ── Redis (optional — enables distributed caching and Bull queues) ─────────────
# # Leave blank to fall back to in-process node-cache and synchronous processing.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# # ── Cache ─────────────────────────────────────────────────────────────────────
# # Default TTL for cached responses (seconds)
# CACHE_TTL_SECONDS=300
# # TTL for catalog endpoint (full product list) — longer because it rarely changes
# CACHE_TTL_CATALOG_SECONDS=600

# # ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=200

# # ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=debug
# LOG_DIR=logs

# # ── SAP BTP / Cloud Foundry  (populated automatically by CF runtime) ──────────
# # These are set by CF when the app is pushed — do NOT set them manually.
# # PORT is overridden by CF; the app reads process.env.PORT at runtime.
# # VCAP_SERVICES contains all bound service credentials as JSON.
