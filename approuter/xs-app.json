{
  "welcomeFile": "/index.html",
  "authenticationMethod": "none",
  "logout": {
    "logoutEndpoint": "/logout"
  },
  "routes": [
    {
      "source":      "^/api/(.*)$",
      "target":      "/api/$1",
      "destination": "api-backend"
    },
    {
      "source":      "^/(.*)$",
      "target":      "/$1",
      "localDir":    "webapp"
    }
  ]
}
