{
  "_version": "1.59.0",
  "sap.app": {
    "id": "com.demo.productcatalog",
    "type": "application",
    "title": "Product Catalog Manager",
    "description": "SAP Fiori CRUD Demo Application for managing product catalogs",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {},
    "i18n": "i18n/i18n.properties"
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://product",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.demo.productcatalog.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.demo.productcatalog.i18n.i18n"
        }
      },
      "products": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {}
      },
      "view": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.demo.productcatalog.view",
        "controlId": "navContainer",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "home",
          "pattern": "",
          "target": "home"
        },
        {
          "name": "productList",
          "pattern": "products",
          "target": "productList"
        },
        {
          "name": "productForm",
          "pattern": "products/new",
          "target": "productForm"
        },
        {
          "name": "productDetail",
          "pattern": "products/{productId}",
          "target": "productDetail"
        },
        {
          "name": "productEdit",
          "pattern": "products/{productId}/edit",
          "target": "productForm"
        }
      ],
      "targets": {
        "home": {
          "viewName": "Home",
          "viewLevel": 1
        },
        "productList": {
          "viewName": "ProductList",
          "viewLevel": 2
        },
        "productDetail": {
          "viewName": "ProductDetail",
          "viewLevel": 3
        },
        "productForm": {
          "viewName": "ProductForm",
          "viewLevel": 3
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    }
  }
}
