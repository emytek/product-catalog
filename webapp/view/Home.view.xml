<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    controllerName="com.demo.productcatalog.controller.Home">

    <f:DynamicPage id="homePage" headerExpanded="true" toggleHeaderOnTitleClick="true">

        <!-- =========================================================== -->
        <!-- DYNAMIC PAGE TITLE                                            -->
        <!-- =========================================================== -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>homeTitle}" level="H1" />
                </f:heading>
                <f:snappedHeading>
                    <Title text="{i18n>homeTitle}" level="H1" />
                </f:snappedHeading>

                <f:actions>
                    <Button
                        text="{i18n>actionBrowseProducts}"
                        type="Emphasized"
                        icon="sap-icon://list"
                        press=".onNavToProductList" />
                    <Button
                        text="{i18n>actionAddProduct}"
                        type="Default"
                        icon="sap-icon://add"
                        press=".onNavToCreateProduct" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- =========================================================== -->
        <!-- DYNAMIC PAGE HEADER — KPI TILES                              -->
        <!-- =========================================================== -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox
                    wrap="Wrap"
                    justifyContent="Start"
                    alignItems="Stretch"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

                    <!-- KPI: Total Products -->
                    <GenericTile
                        class="kpiTile sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        header="{i18n>kpiTotalProducts}"
                        subheader="In catalog"
                        tileContent="[0]"
                        press=".onNavToProductList">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="{viewModel>/stats/totalProducts}"
                                        scale=""
                                        indicator="None"
                                        valueColor="Good" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- KPI: Active Products -->
                    <GenericTile
                        class="kpiTile sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        header="{i18n>kpiActiveProducts}"
                        subheader="Currently available"
                        press=".onNavToProductList">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="{viewModel>/stats/activeProducts}"
                                        scale=""
                                        indicator="None"
                                        valueColor="Good" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- KPI: Total Categories -->
                    <GenericTile
                        class="kpiTile sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        header="{i18n>kpiTotalCategories}"
                        subheader="Product groups"
                        press=".onNavToProductList">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="{viewModel>/stats/totalCategories}"
                                        scale=""
                                        indicator="None"
                                        valueColor="Neutral" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- KPI: Featured Items -->
                    <GenericTile
                        class="kpiTile sapUiSmallMarginEnd sapUiSmallMarginBottom"
                        header="{i18n>kpiFeaturedItems}"
                        subheader="Highlighted products"
                        press=".onNavToProductList">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="{viewModel>/stats/featuredCount}"
                                        scale=""
                                        indicator="None"
                                        valueColor="Neutral" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- =========================================================== -->
        <!-- DYNAMIC PAGE CONTENT                                          -->
        <!-- =========================================================== -->
        <f:content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

                <!-- ================================================== -->
                <!-- SECTION 1: FEATURED PRODUCTS CAROUSEL                -->
                <!-- ================================================== -->
                <Title
                    text="{i18n>homeFeaturedProducts}"
                    level="H2"
                    class="sapUiSmallMarginBottom" />

                <Carousel
                    id="featuredCarousel"
                    class="featuredCarousel sapUiSmallMarginBottom"
                    height="300px"
                    width="100%"
                    loop="true"
                    pages="{viewModel>/featuredProducts}">
                    <FlexBox
                        direction="Column"
                        justifyContent="End"
                        class="carouselPage default">
                        <VBox class="sapUiSmallMargin">
                            <Text
                                text="{viewModel>Category}"
                                class="carouselProductCategory" />
                            <Text
                                text="{viewModel>ProductName}"
                                class="carouselProductName" />
                            <Text
                                text="{parts: [{path: 'viewModel>Price'}, {path: 'viewModel>Currency'}], formatter: '.formatter.formatPrice'}"
                                class="carouselProductPrice" />
                            <Button
                                text="View Details"
                                type="Transparent"
                                press=".onCarouselItemPress"
                                class="sapUiSmallMarginTop" />
                        </VBox>
                    </FlexBox>
                </Carousel>

                <!-- ================================================== -->
                <!-- SECTION 2: QUICK ACTIONS                             -->
                <!-- ================================================== -->
                <Title
                    text="{i18n>homeQuickActions}"
                    level="H2"
                    class="sapUiSmallMarginBottom sapUiMediumMarginTop" />

                <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
                    <Button
                        text="{i18n>actionBrowseProducts}"
                        type="Emphasized"
                        icon="sap-icon://list"
                        press=".onNavToProductList"
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom" />
                    <Button
                        text="{i18n>actionAddProduct}"
                        type="Default"
                        icon="sap-icon://add"
                        press=".onNavToCreateProduct"
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom" />
                    <Button
                        text="View Statistics"
                        type="Default"
                        icon="sap-icon://chart-bar"
                        press=".onShowStats"
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom" />
                    <Button
                        text="{i18n>actionHelp}"
                        type="Default"
                        icon="sap-icon://information"
                        press=".onShowAbout"
                        class="sapUiSmallMarginBottom" />
                </HBox>

                <!-- ================================================== -->
                <!-- SECTION 3: RECENT PRODUCTS                           -->
                <!-- ================================================== -->
                <Title
                    text="{i18n>homeRecentProducts}"
                    level="H2"
                    class="sapUiSmallMarginBottom sapUiMediumMarginTop" />

                <List
                    id="recentProductsList"
                    items="{viewModel>/recentProducts}"
                    mode="None"
                    backgroundDesign="Transparent"
                    noDataText="{i18n>emptyStateTitle}">
                    <ObjectListItem
                        title="{viewModel>ProductName}"
                        number="{parts: [{path: 'viewModel>Price'}, {path: 'viewModel>Currency'}], formatter: '.formatter.formatPrice'}"
                        numberUnit="{viewModel>Currency}"
                        intro="{viewModel>Category} | {viewModel>SubCategory}"
                        type="Navigation"
                        press=".onRecentProductPress">
                        <attributes>
                            <ObjectAttribute
                                title="Status"
                                text="{viewModel>Status}" />
                            <ObjectAttribute
                                title="Supplier"
                                text="{viewModel>Supplier}" />
                        </attributes>
                        <firstStatus>
                            <ObjectStatus
                                text="{viewModel>Status}"
                                state="{path: 'viewModel>Status', formatter: '.formatter.formatStatus'}" />
                        </firstStatus>
                    </ObjectListItem>
                </List>

            </VBox>
        </f:content>

    </f:DynamicPage>

</mvc:View>
