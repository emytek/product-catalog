<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:layout="sap.ui.layout"
    controllerName="com.demo.productcatalog.controller.ProductForm">

    <f:DynamicPage id="productFormPage" headerExpanded="true" toggleHeaderOnTitleClick="false" fitContent="true" showFooter="true">

        <!-- =========================================================== -->
        <!-- DYNAMIC PAGE TITLE                                            -->
        <!-- =========================================================== -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{viewModel>/title}" level="H1" />
                </f:heading>
                <f:snappedHeading>
                    <Title text="{viewModel>/title}" level="H2" />
                </f:snappedHeading>

                <f:actions>
                    <Button
                        text="{i18n>buttonBack}"
                        icon="sap-icon://nav-back"
                        type="Default"
                        press=".onCancel" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- =========================================================== -->
        <!-- DYNAMIC PAGE CONTENT — FORM                                   -->
        <!-- =========================================================== -->
        <f:content>
            <form:SimpleForm
                id="productForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                <form:content>

                    <!-- ============================================== -->
                    <!-- SECTION: BASIC INFORMATION                      -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionBasicInfo}" />

                    <Label text="{i18n>formLabelProductName}" required="true" />
                    <Input
                        id="productNameInput"
                        value="{viewModel>/formData/ProductName}"
                        placeholder="{i18n>placeholderProductName}"
                        valueLiveUpdate="true"
                        maxLength="100" />

                    <Label text="{i18n>formLabelCategory}" required="true" />
                    <Select
                        id="formCategorySelect"
                        selectedKey="{viewModel>/formData/Category}"
                        change=".onCategoryChange">
                        <items>
                            <core:Item key="" text="-- Select Category --" />
                            <core:Item key="Electronics" text="Electronics" />
                            <core:Item key="Furniture" text="Furniture" />
                            <core:Item key="Clothing" text="Clothing" />
                            <core:Item key="Food &amp; Beverage" text="Food &amp; Beverage" />
                            <core:Item key="Office Supplies" text="Office Supplies" />
                        </items>
                    </Select>

                    <Label text="{i18n>formLabelSubCategory}" />
                    <Input
                        id="subCategoryInput"
                        value="{viewModel>/formData/SubCategory}"
                        placeholder="{i18n>placeholderSubCategory}"
                        maxLength="60" />

                    <Label text="{i18n>formLabelStatus}" />
                    <Select
                        id="formStatusSelect"
                        selectedKey="{viewModel>/formData/Status}">
                        <items>
                            <core:Item key="Active" text="Active" />
                            <core:Item key="Inactive" text="Inactive" />
                            <core:Item key="Discontinued" text="Discontinued" />
                        </items>
                    </Select>

                    <!-- ============================================== -->
                    <!-- SECTION: PRICING                                -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionPricing}" />

                    <Label text="{i18n>formLabelPrice}" required="true" />
                    <Input
                        id="priceInput"
                        value="{viewModel>/formData/Price}"
                        placeholder="{i18n>placeholderPrice}"
                        type="Number" />

                    <Label text="{i18n>formLabelCurrency}" />
                    <Select
                        id="currencySelect"
                        selectedKey="{viewModel>/formData/Currency}">
                        <items>
                            <core:Item key="USD" text="USD - US Dollar" />
                            <core:Item key="EUR" text="EUR - Euro" />
                            <core:Item key="GBP" text="GBP - British Pound" />
                        </items>
                    </Select>

                    <Label text="{i18n>formLabelDiscount}" />
                    <VBox>
                        <Slider
                            id="discountSlider"
                            value="{viewModel>/formData/Discount}"
                            min="0"
                            max="50"
                            step="5"
                            width="100%"
                            change=".onDiscountChange"
                            liveChange=".onDiscountChange" />
                        <Text
                            text="Current Discount: {viewModel>/formData/Discount}%"
                            class="sapUiTinyMarginTop" />
                    </VBox>

                    <!-- ============================================== -->
                    <!-- SECTION: INVENTORY                              -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionInventory}" />

                    <Label text="{i18n>formLabelStock}" required="true" />
                    <Input
                        id="stockInput"
                        value="{viewModel>/formData/Stock}"
                        placeholder="{i18n>placeholderStock}"
                        type="Number" />

                    <Label text="{i18n>formLabelUnit}" />
                    <Select
                        id="unitSelect"
                        selectedKey="{viewModel>/formData/Unit}">
                        <items>
                            <core:Item key="EA" text="EA - Each" />
                            <core:Item key="KG" text="KG - Kilogram" />
                            <core:Item key="L" text="L - Litre" />
                            <core:Item key="M" text="M - Metre" />
                        </items>
                    </Select>

                    <!-- ============================================== -->
                    <!-- SECTION: PRODUCT DETAILS                        -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionDetails}" />

                    <Label text="{i18n>formLabelDescription}" />
                    <TextArea
                        id="descriptionInput"
                        value="{viewModel>/formData/Description}"
                        placeholder="{i18n>placeholderDescription}"
                        rows="4"
                        width="100%"
                        maxLength="1000" />

                    <Label text="{i18n>formLabelTags}" />
                    <MultiInput
                        id="tagsInput"
                        placeholder="{i18n>formLabelTagPlaceholder}"
                        tokenUpdate=".onTokenUpdate"
                        submit=".onAddTag"
                        width="100%" />

                    <Label text="{i18n>formLabelFeatured}" />
                    <CheckBox
                        id="featuredCheckBox"
                        selected="{viewModel>/formData/Featured}"
                        text="Mark this product as a featured item" />

                    <!-- ============================================== -->
                    <!-- SECTION: SUPPLIER                               -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionSupplier}" />

                    <Label text="{i18n>formLabelSupplier}" />
                    <Input
                        id="supplierInput"
                        value="{viewModel>/formData/Supplier}"
                        placeholder="{i18n>placeholderSupplier}"
                        maxLength="100" />

                    <!-- ============================================== -->
                    <!-- SECTION: PHYSICAL SPECIFICATIONS                -->
                    <!-- ============================================== -->
                    <core:Title text="{i18n>formSectionPhysical}" />

                    <Label text="{i18n>formLabelWeight}" />
                    <Input
                        id="weightInput"
                        value="{viewModel>/formData/Weight}"
                        placeholder="{i18n>placeholderWeight}"
                        maxLength="30" />

                    <Label text="{i18n>formLabelDimensions}" />
                    <Input
                        id="dimensionsInput"
                        value="{viewModel>/formData/Dimensions}"
                        placeholder="{i18n>placeholderDimensions}"
                        maxLength="60" />

                </form:content>
            </form:SimpleForm>
        </f:content>

        <!-- =========================================================== -->
        <!-- FOOTER BAR — SAVE / CANCEL                                    -->
        <!-- =========================================================== -->
        <f:footer>
            <OverflowToolbar class="formFooterBar">
                <ToolbarSpacer />
                <Button
                    id="saveButton"
                    text="{viewModel>/saveButtonText}"
                    type="Emphasized"
                    icon="sap-icon://save"
                    press=".onSave" />
                <Button
                    text="{i18n>buttonCancel}"
                    type="Default"
                    icon="sap-icon://decline"
                    press=".onCancel" />
            </OverflowToolbar>
        </f:footer>

    </f:DynamicPage>

</mvc:View>
